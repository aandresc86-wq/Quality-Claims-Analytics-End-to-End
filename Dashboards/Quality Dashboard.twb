    <worksheet name='Priority Score'>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_quality_claims+ (QualityClaimsDB)' name='federated.17yoei80t9wbzm14t5q8p18sqcyf' />
          </datasources>
          <datasource-dependencies datasource='federated.17yoei80t9wbzm14t5q8p18sqcyf'>
            <column caption='TotalClaim' datatype='integer' name='[Calculation_1977487891124224]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([claim_id])' />
            </column>
            <column caption='ClaimMonth' datatype='datetime' name='[Calculation_1977487895281675]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [claim_open_date])' />
            </column>
            <column caption='Open Claim Aging Days' datatype='integer' name='[Calculation_1977487898386461]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [claim_status] = &quot;Open&quot; OR [claim_status] = &quot;Pending&quot; OR [claim_status] = &quot;In Analysis&quot; THEN&#13;&#10;DATEDIFF(&apos;day&apos;, [claim_open_date], TODAY())&#13;&#10;ELSE&#13;&#10;[days_to_close]&#13;&#10;END' />
            </column>
            <column caption='Priority Score' datatype='real' name='[Calculation_1977487899476004]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;(SUM([cost_impact_usd]) / WINDOW_MAX(SUM([cost_impact_usd]))) * 0.40&#13;&#10;)&#13;&#10;+&#13;&#10;(&#13;&#10;(COUNTD([claim_id]) / WINDOW_MAX(COUNTD([claim_id]))) * 0.25&#13;&#10;)&#13;&#10;+&#13;&#10;(&#13;&#10;((SUM(INT([recurrence_flag])) / COUNTD([claim_id]))&#13;&#10;/ WINDOW_MAX(SUM(INT([recurrence_flag])) / COUNTD([claim_id]))) * 0.20&#13;&#10;)&#13;&#10;+&#13;&#10;(&#13;&#10;(AVG([Calculation_1977487898386461]) / WINDOW_MAX(AVG([Calculation_1977487898386461]))) * 0.15&#13;&#10;)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Application Type' datatype='string' name='[application_type]' role='dimension' type='nominal' />
            <column caption='Business Unit' datatype='string' name='[business_unit]' role='dimension' type='nominal' />
            <column caption='Claim Id' datatype='string' name='[claim_id]' role='dimension' type='nominal' />
            <column caption='Claim Open Date' datatype='date' name='[claim_open_date]' role='dimension' type='ordinal' />
            <column caption='Claim Status' datatype='string' name='[claim_status]' role='dimension' type='nominal' />
            <column caption='Claim Type' datatype='string' name='[claim_type]' role='dimension' type='nominal' />
            <column caption='Cost Impact Usd' datatype='real' name='[cost_impact_usd]' role='measure' type='quantitative' />
            <column caption='Country' datatype='string' name='[country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column caption='Customer Region' datatype='string' name='[customer_region]' role='dimension' type='nominal' />
            <column caption='Days To Close' datatype='integer' name='[days_to_close]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1977487895281675]' derivation='Month' name='[mn:Calculation_1977487895281675:ok]' pivot='key' type='ordinal' />
            <column-instance column='[application_type]' derivation='None' name='[none:application_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[business_unit]' derivation='None' name='[none:business_unit:nk]' pivot='key' type='nominal' />
            <column-instance column='[claim_status]' derivation='None' name='[none:claim_status:nk]' pivot='key' type='nominal' />
            <column-instance column='[claim_type]' derivation='None' name='[none:claim_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[country]' derivation='None' name='[none:country:nk]' pivot='key' type='nominal' />
            <column-instance column='[customer_region]' derivation='None' name='[none:customer_region:nk]' pivot='key' type='nominal' />
            <column-instance column='[product_family]' derivation='None' name='[none:product_family:nk]' pivot='key' type='nominal' />
            <column-instance column='[root_cause_category]' derivation='None' name='[none:root_cause_category:nk]' pivot='key' type='nominal' />
            <column-instance column='[severity_level]' derivation='None' name='[none:severity_level:nk]' pivot='key' type='nominal' />
            <column caption='Product Family' datatype='string' name='[product_family]' role='dimension' type='nominal' />
            <column caption='Recurrence Flag' datatype='boolean' name='[recurrence_flag]' role='dimension' type='nominal' />
            <column caption='Root Cause Category' datatype='string' name='[root_cause_category]' role='dimension' type='nominal' />
            <column caption='Severity Level' datatype='string' name='[severity_level]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1977487891124224]' derivation='User' name='[usr:Calculation_1977487891124224:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1977487899476004]' derivation='User' name='[usr:Calculation_1977487899476004:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Columns' />
            </column-instance>
