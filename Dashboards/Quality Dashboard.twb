      <aliases enabled='yes' />
      <column caption='TotalClaim' datatype='integer' name='[Calculation_1977487891124224]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([claim_id])' />
      </column>
      <column caption='TotalCostImpact' datatype='real' name='[Calculation_1977487891386369]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([cost_impact_usd])' />
      </column>
      <column caption='AvDaystoClose' datatype='real' name='[Calculation_1977487891738626]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([days_to_close])' />
      </column>
      <column caption='RecurringClaim' datatype='integer' name='[Calculation_1977487892008963]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT([recurrence_flag]))' />
      </column>
      <column caption='RecRate%' datatype='real' name='[Calculation_1977487893864452]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT([recurrence_flag])) / COUNTD([claim_id])' />
      </column>
      <column caption='TotalQuaAffected' datatype='integer' name='[Calculation_1977487894208517]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([quantity_affected])' />
      </column>
      <column caption='AvgCostperClaim' datatype='real' name='[Calculation_1977487894364166]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([cost_impact_usd]) / COUNTD([claim_id])' />
      </column>
      <column caption='HighCritClaims' datatype='integer' name='[Calculation_1977487894528007]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [severity_level] = &quot;High&quot; OR [severity_level] = &quot;Critical&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='HighCritShare%' datatype='real' name='[Calculation_1977487894679560]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [severity_level] = &quot;High&quot; OR [severity_level] = &quot;Critical&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;) / COUNTD([claim_id])' />
      </column>
      <column caption='OpenClaims' datatype='integer' name='[Calculation_1977487895003145]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [claim_status] = &quot;Open&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='ClosedClaims' datatype='integer' name='[Calculation_1977487895162890]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [claim_status] = &quot;Closed&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='ClaimMonth' datatype='datetime' name='[Calculation_1977487895281675]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [claim_open_date])' />
      </column>
      <column caption='ClaimYear' datatype='integer' name='[Calculation_1977487895457804]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([claim_open_date])' />
      </column>
      <column caption='MonthLabel' datatype='string' name='[Calculation_1977487896199181]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;month&apos;, [claim_open_date])' />
      </column>
      <column caption='ClaimsPrevMonth' datatype='integer' name='[Calculation_1977487896395790]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOOKUP(COUNTD([claim_id]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Claims MoM Growth %' datatype='real' name='[Calculation_1977487896645647]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;COUNTD([claim_id]) - LOOKUP(COUNTD([claim_id]), -1)&#13;&#10;)&#13;&#10;/&#13;&#10;ABS(LOOKUP(COUNTD([claim_id]), -1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Cost MoM Growth %' datatype='real' name='[Calculation_1977487896825872]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;SUM([cost_impact_usd]) - LOOKUP(SUM([cost_impact_usd]), -1)&#13;&#10;)&#13;&#10;/&#13;&#10;ABS(LOOKUP(SUM([cost_impact_usd]), -1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Rolling 3-Month Avg Claims' datatype='real' name='[Calculation_1977487896973329]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(COUNTD([claim_id]), -2, 0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Root Cause Cost' datatype='real' name='[Calculation_1977487897100306]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([cost_impact_usd])' />
      </column>
      <column caption='Running Cost' datatype='real' name='[Calculation_1977487897198611]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([cost_impact_usd]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Pareto Cumulative % Cost' datatype='real' name='[Calculation_1977487897325588]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([cost_impact_usd])) / WINDOW_SUM(SUM([cost_impact_usd]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Root Cause Rank by Cost' datatype='integer' name='[Calculation_1977487897452565]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(SUM([cost_impact_usd]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Root Cause Recurrence Rate %' datatype='real' name='[Calculation_1977487897575446]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT([recurrence_flag])) / COUNTD([claim_id])' />
      </column>
      <column caption='Claims per Customer' datatype='integer' name='[Calculation_1977487897714711]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_id] : COUNTD([claim_id]) }' />
      </column>
      <column caption='Cost per Customer' datatype='real' name='[Calculation_1977487897927704]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_id] : SUM([cost_impact_usd]) }' />
      </column>
      <column caption='Claims per Product Family' datatype='integer' name='[Calculation_1977487898079257]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [product_family] : COUNTD([claim_id]) }' />
      </column>
      <column caption='Cost per Product Family' datatype='real' name='[Calculation_1977487898165274]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [product_family] : SUM([cost_impact_usd]) }' />
      </column>
      <column caption='Cost per Supplier' datatype='real' name='[Calculation_1977487898239003]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [supplier_id] : SUM([cost_impact_usd]) }' />
      </column>
      <column caption='Avg Days to Close per Supplier' datatype='real' name='[Calculation_1977487898304540]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [supplier_id] : AVG([days_to_close]) }' />
      </column>
      <column caption='Open Claim Aging Days' datatype='integer' name='[Calculation_1977487898386461]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [claim_status] = &quot;Open&quot; OR [claim_status] = &quot;Pending&quot; OR [claim_status] = &quot;In Analysis&quot; THEN&#13;&#10;DATEDIFF(&apos;day&apos;, [claim_open_date], TODAY())&#13;&#10;ELSE&#13;&#10;[days_to_close]&#13;&#10;END' />
      </column>
      <column caption='Aging Bucket' datatype='string' name='[Calculation_1977487898558494]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1977487898386461] &lt;= 7 THEN &quot;0-7 days&quot;&#13;&#10;ELSEIF [Calculation_1977487898386461] &lt;= 15 THEN &quot;8-15 days&quot;&#13;&#10;ELSEIF [Calculation_1977487898386461] &lt;= 30 THEN &quot;16-30 days&quot;&#13;&#10;ELSEIF [Calculation_1977487898386461] &lt;= 60 THEN &quot;31-60 days&quot;&#13;&#10;ELSE &quot;61+ days&quot;&#13;&#10;END' />
      </column>
      <column caption='Severity Score' datatype='integer' name='[Calculation_1977487898894367]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [severity_level]&#13;&#10;WHEN &quot;Low&quot; THEN 1&#13;&#10;WHEN &quot;Medium&quot; THEN 2&#13;&#10;WHEN &quot;High&quot; THEN 3&#13;&#10;WHEN &quot;Critical&quot; THEN 4&#13;&#10;END' />
      </column>
      <column caption='Avg Severity Score' datatype='real' name='[Calculation_1977487899000864]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_1977487898894367])' />
      </column>
      <column caption='Normalized Cost' datatype='real' name='[Calculation_1977487899062305]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([cost_impact_usd]) / WINDOW_MAX(SUM([cost_impact_usd]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Normalized Claim Volume' datatype='real' name='[Calculation_1977487899164706]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([claim_id]) / WINDOW_MAX(COUNTD([claim_id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Normalized Recurrence' datatype='real' name='[Calculation_1977487899250723]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;SUM(INT([recurrence_flag])) / COUNTD([claim_id])&#13;&#10;)&#13;&#10;/&#13;&#10;WINDOW_MAX(&#13;&#10;SUM(INT([recurrence_flag])) / COUNTD([claim_id])&#13;&#10;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Priority Score' datatype='real' name='[Calculation_1977487899476004]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;(SUM([cost_impact_usd]) / WINDOW_MAX(SUM([cost_impact_usd]))) * 0.40&#13;&#10;)&#13;&#10;+&#13;&#10;(&#13;&#10;(COUNTD([claim_id]) / WINDOW_MAX(COUNTD([claim_id]))) * 0.25&#13;&#10;)&#13;&#10;+&#13;&#10;(&#13;&#10;((SUM(INT([recurrence_flag])) / COUNTD([claim_id]))&#13;&#10;/ WINDOW_MAX(SUM(INT([recurrence_flag])) / COUNTD([claim_id]))) * 0.20&#13;&#10;)&#13;&#10;+&#13;&#10;(&#13;&#10;(AVG([Calculation_1977487898386461]) / WINDOW_MAX(AVG([Calculation_1977487898386461]))) * 0.15&#13;&#10;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Cost Share %' datatype='real' name='[Calculation_1977487899705381]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([cost_impact_usd]) / WINDOW_SUM(SUM([cost_impact_usd]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Claim Share %' datatype='real' name='[Calculation_1977487899783206]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([claim_id]) / WINDOW_SUM(COUNTD([claim_id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='First Claim Date per Customer' datatype='date' name='[Calculation_1977487899926567]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [customer_id] : MIN([claim_open_date]) }' />
      </column>
