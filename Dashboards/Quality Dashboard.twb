    <worksheet name='Table2'>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_quality_claims+ (QualityClaimsDB)' name='federated.17yoei80t9wbzm14t5q8p18sqcyf' />
          </datasources>
          <datasource-dependencies datasource='federated.17yoei80t9wbzm14t5q8p18sqcyf'>
            <column caption='TotalClaim' datatype='integer' name='[Calculation_1977487891124224]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([claim_id])' />
            </column>
            <column caption='TotalCostImpact' datatype='real' name='[Calculation_1977487891386369]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([cost_impact_usd])' />
            </column>
            <column caption='AvDaystoClose' datatype='real' name='[Calculation_1977487891738626]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([days_to_close])' />
            </column>
            <column caption='RecRate%' datatype='real' name='[Calculation_1977487893864452]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(INT([recurrence_flag])) / COUNTD([claim_id])' />
            </column>
            <column caption='ClaimMonth' datatype='datetime' name='[Calculation_1977487895281675]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [claim_open_date])' />
            </column>
            <column caption='Open Claim Aging Days' datatype='integer' name='[Calculation_1977487898386461]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [claim_status] = &quot;Open&quot; OR [claim_status] = &quot;Pending&quot; OR [claim_status] = &quot;In Analysis&quot; THEN&#13;&#10;DATEDIFF(&apos;day&apos;, [claim_open_date], TODAY())&#13;&#10;ELSE&#13;&#10;[days_to_close]&#13;&#10;END' />
            </column>
            <column caption='Priority Score' datatype='real' name='[Calculation_1977487899476004]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;(SUM([cost_impact_usd]) / WINDOW_MAX(SUM([cost_impact_usd]))) * 0.40&#13;&#10;)&#13;&#10;+&#13;&#10;(&#13;&#10;(COUNTD([claim_id]) / WINDOW_MAX(COUNTD([claim_id]))) * 0.25&#13;&#10;)&#13;&#10;+&#13;&#10;(&#13;&#10;((SUM(INT([recurrence_flag])) / COUNTD([claim_id]))&#13;&#10;/ WINDOW_MAX(SUM(INT([recurrence_flag])) / COUNTD([claim_id]))) * 0.20&#13;&#10;)&#13;&#10;+&#13;&#10;(&#13;&#10;(AVG([Calculation_1977487898386461]) / WINDOW_MAX(AVG([Calculation_1977487898386461]))) * 0.15&#13;&#10;)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Application Type' datatype='string' name='[application_type]' role='dimension' type='nominal' />
            <column caption='Business Unit' datatype='string' name='[business_unit]' role='dimension' type='nominal' />
            <column caption='Claim Id' datatype='string' name='[claim_id]' role='dimension' type='nominal' />
            <column caption='Claim Open Date' datatype='date' name='[claim_open_date]' role='dimension' type='ordinal' />
